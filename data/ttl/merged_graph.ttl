@prefix cosmo: <http://example.org/cosmology/> .
@prefix ex: <http://example.org/resource/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cosmo:Cluster a rdfs:Class .

cosmo:Instrument a rdfs:Class .

cosmo:Measurement a rdfs:Class .

cosmo:Observation a rdfs:Class .

cosmo:Publication a rdfs:Class .

cosmo:Survey a rdfs:Class .

cosmo:hasMeasurement a rdf:Property ;
    rdfs:domain cosmo:Cluster ;
    rdfs:range cosmo:Measurement .

cosmo:hasObservation a rdf:Property ;
    rdfs:domain cosmo:Cluster ;
    rdfs:range cosmo:Observation .

cosmo:hasUncertainty a rdf:Property ;
    rdfs:domain cosmo:Measurement ;
    rdfs:range xsd:decimal .

cosmo:measurementType a rdf:Property ;
    rdfs:domain cosmo:Measurement .

cosmo:measurementValue a rdf:Property ;
    rdfs:domain cosmo:Measurement ;
    rdfs:range xsd:decimal .

cosmo:observedInSurvey a rdf:Property ;
    rdfs:domain cosmo:Observation ;
    rdfs:range cosmo:Survey .

cosmo:reportedIn a rdf:Property ;
    rdfs:domain cosmo:Measurement ;
    rdfs:range cosmo:Publication .

cosmo:usedInstrument a rdf:Property ;
    rdfs:domain cosmo:Observation ;
    rdfs:range cosmo:Instrument .

ex:cluster_abell1689 a cosmo:Cluster ;
    rdfs:label "Abell 1689" ;
    cosmo:hasMeasurement ex:m_mass_001,
        ex:m_redshift_001 ;
    cosmo:hasObservation ex:obs_001 .

ex:instrument_wfc3 a cosmo:Instrument ;
    rdfs:label "WFC3" .

ex:m_mass_001 a cosmo:Measurement ;
    cosmo:hasUncertainty 0.1 ;
    cosmo:measurementType "mass" ;
    cosmo:measurementValue 2.0 ;
    cosmo:reportedIn ex:paper_001 .

ex:m_redshift_001 a cosmo:Measurement ;
    cosmo:hasUncertainty 0.002 ;
    cosmo:measurementType "redshift" ;
    cosmo:measurementValue 0.183 ;
    cosmo:reportedIn ex:paper_001 .

ex:obs_001 a cosmo:Observation ;
    cosmo:observedInSurvey ex:survey_hst ;
    cosmo:usedInstrument ex:instrument_wfc3 .

ex:survey_hst a cosmo:Survey ;
    rdfs:label "Hubble Survey" .

ex:paper_001 a cosmo:Publication ;
    rdfs:label "Example Cluster Paper" .

